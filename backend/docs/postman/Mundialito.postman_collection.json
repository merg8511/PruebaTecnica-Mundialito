    {
      "name": "Idempotency",
      "description": "Casos de prueba de idempotencia para POST /teams.\n\nEjecutar en ORDEN (1→2→3→4) para que el key sea consistente.\n\nAntes de ejecutar, asegurarse que el equipo 'Idempotency Test Team' no existe.",
      "item": [
        {
          "name": "1. POST /teams — Missing Idempotency-Key → 400",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"name\": \"Should Fail No Header\"}" },
            "url": { "raw": "{{baseUrl}}/teams", "host": ["{{baseUrl}}"], "path": ["teams"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('400 Bad Request', () => pm.response.to.have.status(400));",
                  "const body = pm.response.json();",

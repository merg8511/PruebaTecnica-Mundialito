                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('search filters results', () => {",
                  "  body.data.forEach(t => pm.expect(t.name.toLowerCase()).to.include('alpha'));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },

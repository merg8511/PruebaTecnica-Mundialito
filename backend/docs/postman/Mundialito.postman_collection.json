    {
      "name": "Results",
      "description": "Registro de resultados de partidos. POST requiere Idempotency-Key.",
      "item": [
        {
          "name": "POST /matches/{matchId}/results — Record result",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "result-key-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"homeGoals\": 2,\n  \"awayGoals\": 1,\n  \"goalsByPlayer\": [\n    { \"playerId\": \"{{playerId}}\", \"goals\": 2 }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/matches/{{matchId}}/results",
              "host": ["{{baseUrl}}"],
              "path": ["matches", "{{matchId}}", "results"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Must be called with a Scheduled match and valid player from the match teams",
                  "pm.test('201 or business error', () => {",
                  "  pm.expect([201, 400, 404, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code !== 201) {",
                  "  const body = pm.response.json();",
                  "  pm.test('error envelope present', () => {",
                  "    pm.expect(body).to.have.property('errorCode');",
                  "    pm.expect(body).to.have.property('message');",
                  "    pm.expect(body).to.have.property('traceId');",
                  "  });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Standings",
      "description": "Tabla de posiciones. Read-only. Orden fijo: points DESC, goalDifference DESC, goalsFor DESC.",
      "item": [
        {
          "name": "GET /standings",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/standings", "host": ["{{baseUrl}}"], "path": ["standings"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('envelope shape', () => {",
                  "  pm.expect(body).to.have.property('data').that.is.an('array');",
                  "  pm.expect(body).to.have.property('pageNumber');",
                  "  pm.expect(body).to.have.property('totalRecords');",
                  "});",
                  "pm.test('standing item shape', () => {",
                  "  if (body.data.length > 0) {",
                  "    const item = body.data[0];",
                  "    pm.expect(item).to.have.property('teamId');",
                  "    pm.expect(item).to.have.property('teamName');",
                  "    pm.expect(item).to.have.property('played');",
                  "    pm.expect(item).to.have.property('wins');",
                  "    pm.expect(item).to.have.property('draws');",
                  "    pm.expect(item).to.have.property('losses');",
                  "    pm.expect(item).to.have.property('goalsFor');",
                  "    pm.expect(item).to.have.property('goalsAgainst');",
                  "    pm.expect(item).to.have.property('goalDifference');",
                  "    pm.expect(item).to.have.property('points');",
                  "  }",
                  "});",
                  "pm.test('orden: points descendente', () => {",
                  "  const pts = body.data.map(s => s.points);",
                  "  for (let i = 1; i < pts.length; i++) {",
                  "    pm.expect(pts[i]).to.be.at.most(pts[i-1]);",
                  "  }",
                  "});",
                  "// Con seed: Manchester City 4pts, Real Madrid 3pts, Barcelona 1pt, Arsenal 0pts",
                  "pm.test('seed: Manchester City primero (4 pts)', () => {",
                  "  if (body.totalRecords >= 4) {",
                  "    pm.expect(body.data[0].teamName).to.equal('Manchester City');",
                  "    pm.expect(body.data[0].points).to.equal(4);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },

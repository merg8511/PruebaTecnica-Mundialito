              "script": {
                "exec": [
                  "// Note: may return 400 VALIDATION_ERROR if homeTeam == awayTeam (required for real test)",
                  "const status = pm.response.status;",
                  "pm.test('status is 201 or 400 (same team guard)', () => {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('matchId', pm.response.json().id);",

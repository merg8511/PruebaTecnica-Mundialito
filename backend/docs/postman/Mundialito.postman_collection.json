{
  "info": {
    "name": "Mundialito de Fútbol — API",
    "_postman_id": "mundialito-api-collection-v1",
    "description": "Colección completa de la API REST del Mundialito de Fútbol Corporativo.\n\nCubre todos los endpoints con casos de idempotencia, paginación, filtros, errores y flujo completo.\n\n**Requisitos**: Tener la API corriendo (docker-compose up --build) o `dotnet run`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "teamId", "value": "", "type": "string" },
    { "key": "matchId", "value": "", "type": "string" },
    { "key": "playerId", "value": "", "type": "string" },
    { "key": "idempKey", "value": "test-key-001", "type": "string" }
  ],
  "item": [
    {
      "name": "Teams",
      "description": "CRUD de equipos. POST requiere Idempotency-Key.",
      "item": [
        {
          "name": "POST /teams — Create (first)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "{{idempKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Team Alpha\"}"
            },
            "url": { "raw": "{{baseUrl}}/teams", "host": ["{{baseUrl}}"], "path": ["teams"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('has id, name, createdAt', () => {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body).to.have.property('name', 'Team Alpha');",
                  "  pm.expect(body).to.have.property('createdAt');",
                  "});",
                  "pm.collectionVariables.set('teamId', body.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /teams — List (paginado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/teams?pageNumber=1&pageSize=10&sortBy=name&sortDirection=asc",
              "host": ["{{baseUrl}}"],
              "path": ["teams"],
              "query": [
                { "key": "pageNumber", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "sortBy", "value": "name" },
                { "key": "sortDirection", "value": "asc" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('envelope shape', () => {",
                  "  pm.expect(body).to.have.property('data').that.is.an('array');",
                  "  pm.expect(body).to.have.property('pageNumber', 1);",
                  "  pm.expect(body).to.have.property('pageSize', 10);",
                  "  pm.expect(body).to.have.property('totalRecords');",
                  "  pm.expect(body).to.have.property('totalPages');",

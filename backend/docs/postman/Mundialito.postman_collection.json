    {
      "name": "Matches",
      "description": "CRUD de partidos. POST requiere Idempotency-Key.",
      "item": [
        {
          "name": "POST /matches — Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Idempotency-Key", "value": "match-key-001" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"homeTeamId\": \"{{teamId}}\", \"awayTeamId\": \"{{teamId}}\", \"scheduledAt\": \"2026-06-01T18:00:00Z\"}"
